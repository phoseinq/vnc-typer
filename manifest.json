{
  "manifest_version": 3,
  "name": "VNC Typer",
  "version": "1.0.0",
  "description": "Type passwords or commands into noVNC / web-VNC sessions using real keyboard events (no clipboard needed).",
  "permissions": ["debugger", "scripting", "storage", "activeTab"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "VNC Typer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
